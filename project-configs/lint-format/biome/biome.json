{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"assist": {
		"actions": {
			"recommended": false,
			"source": {
				"noDuplicateClasses": "off",
				"organizeImports": "on",
				"recommended": false,
				"useSortedAttributes": "on",
				"useSortedInterfaceMembers": "on",
				"useSortedKeys": "off",
				"useSortedProperties": "on"
			}
		},
		"enabled": true
	},
	"css": {
		"formatter": {
			"quoteStyle": "single"
		},
		"parser": {
			"allowWrongLineComments": false,
			"cssModules": true,
			"tailwindDirectives": false
		}
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["app/**/*", "server/**/*", "electron/**/*", "*.{ts,tsx,js,jsx,json}"],
		"maxSize": 2097152
	},
	"formatter": {
		"bracketSpacing": true,
		"enabled": true,
		"expand": "auto",
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineEnding": "lf",
		"lineWidth": 120,
		"trailingNewline": true,
		"useEditorconfig": false
	},
	"graphql": {
		"assist": {
			"enabled": false
		},
		"formatter": {
			"enabled": false
		},
		"linter": {
			"enabled": false
		}
	},
	"grit": {
		"assist": {
			"enabled": false
		},
		"formatter": {
			"enabled": false
		},
		"linter": {
			"enabled": false
		}
	},
	"html": {
		"experimentalFullSupportEnabled": false,
		"formatter": {
			"indentScriptAndStyle": false,
			"selfCloseVoidElements": "always"
		},
		"parser": { "interpolation": true }
	},
	"javascript": {
		"experimentalEmbeddedSnippetsEnabled": false,
		"formatter": {
			"arrowParentheses": "always",
			"attributePosition": "auto",
			"bracketSameLine": false,
			"jsxQuoteStyle": "single",
			"operatorLinebreak": "before",
			"quoteProperties": "asNeeded",
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "none"
		},
		"jsxRuntime": "transparent",
		"parser": {
			"gritMetavariables": false,
			"jsxEverywhere": true,
			"unsafeParameterDecoratorsEnabled": false
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		},
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": false
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"a11y": "on",
			"complexity": {
				"useLiteralKeys": "off",
				"noExcessiveLinesPerFunction": "off"
			},
			"correctness": { "useQwikValidLexicalScope": "off" },
			"nursery": "off",
			"performance": "on",
			"security": { "noGlobalEval": "error" },
			"style": { "useBlockStatements": "off" },
			"suspicious": { "noConsole": "warn" }
		}
	},
	"root": true,
	"vcs": {
		"clientKind": "git",
		"defaultBranch": "main",
		"enabled": true,
		"root": ".",
		"useIgnoreFile": true
	},
	"overrides": [
		{
			"includes": ["server/**/*", "electron/**/*"],
			"javascript": {
				"parser": {
					"jsxEverywhere": false
				}
			},
			"linter": {
				"rules": {
					"correctness": {
						"noNodejsModules": "off",
						"noProcessGlobal": "off"
					}
				}
			}
		},
		{
			"includes": ["vite.config.ts", "electron/**/*"],
			"linter": {
				"rules": {
					"correctness": {
						"noNodejsModules": "off"
					}
				}
			}
		}
	]
}
