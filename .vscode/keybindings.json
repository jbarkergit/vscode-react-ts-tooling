//  VSCode Keybindings - Custom WASD-style Navigation
//
//  QUICK OPEN / COMMAND PALETTE (when open)
//  alt+w               Navigate to previous item
//  alt+s               Navigate to next item
//
//  SIDEBAR ACTIONS
//  alt+z               Toggle visibility
//
//  EDITOR MOVEMENT
//  alt+w               Move cursor up
//  alt+s               Move cursor down
//  alt+a               Move cursor left
//  alt+d               Move cursor right
//  alt+q               Jump word left
//  alt+e               Jump word right
//
//  EDITOR SELECTION
//  alt+shift+w         Select up
//  alt+shift+s         Select down
//  alt+shift+a         Select left
//  alt+shift+d         Select right
//
//  LINE MANIPULATION (move)
//  alt+r               Move line up
//  alt+f               Move line down
//
//  LINE MANIPULATION (copy)
//  alt+shift+r         Copy line up
//  alt+shift+f         Copy line down
//
//  AUTOCOMPLETE DROPDOWN (when suggestion visible)
//  alt+w               Previous suggestion
//  alt+s               Next suggestion
//
//  PARAMETER HINTS (when hints visible)
//  alt+w               Previous parameter hint
//  alt+s               Next parameter hint
//
//  TERMINAL ACTIONS
//  alt+shift+x         Kill terminal
//  alt+shift+c         Toggle terminal
//  alt+shift+v         New terminal
//
//  TERMINAL IN FOCUS MOVEMENT
//  alt+w               Move up (scroll)
//  alt+s               Move down (scroll)
//  alt+a               Move left one char
//  alt+d               Move right one char
//  alt+q               Jump word left
//  alt+e               Jump word right
//
[
    // QUICK OPEN / COMMAND PALETTE
    {
        "key": "alt+w",
        "command": "workbench.action.quickOpenNavigatePrevious",
        "when": "inQuickOpen"
    },
    {
        "key": "alt+s",
        "command": "workbench.action.quickOpenNavigateNext",
        "when": "inQuickOpen"
    },
    // SIDEBAR ACTIONS
    {
        "key": "alt+z",
        "command": "workbench.action.toggleSidebarVisibility"
    },
    // EDITOR MOVEMENT
    {
        "key": "alt+w",
        "command": "cursorUp",
        "when": "editorTextFocus && !suggestWidgetVisible && !parameterHintsVisible"
    },
    {
        "key": "alt+s",
        "command": "cursorDown",
        "when": "editorTextFocus && !suggestWidgetVisible && !parameterHintsVisible"
    },
    {
        "key": "alt+a",
        "command": "cursorLeft",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+d",
        "command": "cursorRight",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+q",
        "command": "cursorWordLeft",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+e",
        "command": "cursorWordRight",
        "when": "editorTextFocus"
    },
    // EDITOR SELECTION
    {
        "key": "alt+shift+w",
        "command": "cursorUpSelect",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+shift+s",
        "command": "cursorDownSelect",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+shift+a",
        "command": "cursorLeftSelect",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+shift+d",
        "command": "cursorRightSelect",
        "when": "editorTextFocus"
    },
    // LINE MANIPULATION (move)
    {
        "key": "alt+r",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+f",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus"
    },
    // LINE MANIPULATION (copy)
    {
        "key": "alt+shift+r",
        "command": "editor.action.copyLinesUpAction",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+shift+f",
        "command": "editor.action.copyLinesDownAction",
        "when": "editorTextFocus"
    },
    // AUTOCOMPLETE DROPDOWN
    {
        "key": "alt+w",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetVisible || suggestWidgetMultipleSuggestions"
    },
    {
        "key": "alt+s",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetVisible || suggestWidgetMultipleSuggestions"
    },
    // PARAMETER HINTS
    {
        "key": "alt+w",
        "command": "showPrevParameterHint",
        "when": "parameterHintsVisible"
    },
    {
        "key": "alt+s",
        "command": "showNextParameterHint",
        "when": "parameterHintsVisible"
    },
    // TERMINAL ACTIONS
    {
        "key": "alt+shift+x",
        "command": "workbench.action.terminal.kill",
        "when": "terminalHasBeenCreated"
    },
    {
        "key": "alt+shift+c",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    {
        "key": "alt+shift+v",
        "command": "workbench.action.terminal.new"
    },
    // TERMINAL IN FOCUS MOVEMENT
    {
        "key": "alt+w",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b[A"
        },
        "when": "terminalFocus"
    },
    {
        "key": "alt+s",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b[B"
        },
        "when": "terminalFocus"
    },
    {
        "key": "alt+a",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b[D"
        },
        "when": "terminalFocus"
    },
    {
        "key": "alt+d",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b[C"
        },
        "when": "terminalFocus"
    },
    {
        "key": "alt+q",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001bb"
        },
        "when": "terminalFocus"
    },
    {
        "key": "alt+e",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001bf"
        },
        "when": "terminalFocus"
    }
]
